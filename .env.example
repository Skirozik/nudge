# ─── Database (matches docker-compose) ─────────────────────────
DATABASE_URL=postgresql://nudge:nudge@localhost:5432/nudge

# ─── Redis (matches docker-compose) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── BlueBubbles ────────────────────────────────────────────────
# URL of your BlueBubbles server (running on your Mac)
BLUEBUBBLES_URL=http://192.168.1.x:1234

# Password you set in BlueBubbles server settings
BLUEBUBBLES_PASSWORD=your_bluebubbles_password

# Use private-api for typing indicators (requires SIP disabled on Mac)
BLUEBUBBLES_METHOD=private-api

# ─── Webhook Security ───────────────────────────────────────────
# Append ?secret=THIS_VALUE to your BlueBubbles webhook URL
WEBHOOK_SECRET=generate_a_long_random_string_here

# ─── Anthropic ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Session Auth ───────────────────────────────────────────────
# Any long random string used to sign JWT session tokens
SESSION_SECRET=generate_another_long_random_string_here

# ─── App URL ────────────────────────────────────────────────────
# Public URL of the deployed app (used for dashboard links sent via iMessage)
APP_URL=https://your-vercel-url.vercel.app
